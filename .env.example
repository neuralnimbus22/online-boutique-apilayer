# Server
PORT=3000

# Postgres — used for product persistence (POST/GET/DELETE /products).
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=apilayer

# Redis — used for the cache-aside layer (GET /products/:id) and the
# view counter (POST/GET /products/:id/view[s]).
REDIS_HOST=localhost
REDIS_PORT=6379

# Tests — used by tests/api.test.js to point at a running instance.
API_URL=http://localhost:3000
